APP_NAME="E-Billing"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-ebilling-domain.example
APP_FORCE_HTTPS=false

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=mysql
# Nixpacks PHP currently works with MariaDB, or with MySQL users that do not
# require caching_sha2_password. MySQL 8 default users may fail to authenticate.
DB_HOST=
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

MAIL_MAILER=log

TRIPAY_API_KEY=
TRIPAY_PRIVATE_KEY=
TRIPAY_MERCHANT_CODE=
TRIPAY_BASE_URL=https://tripay.co.id/api

WHATSPIE_API_KEY=
WHATSPIE_DEVICE_ID=

LEGACY_SCRAPER_URL=http://scraping-ebilling.103.156.128.102.sslip.io

VITE_APP_NAME="${APP_NAME}"
