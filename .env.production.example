APP_NAME="Skynet E-Billing"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_FORCE_HTTPS=true
APP_URL=https://billing.skynet.id
APP_PORT=8080

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=skynet_ebilling
DB_USERNAME=skynet
DB_PASSWORD=change_this_strong_database_password
DB_ROOT_PASSWORD=change_this_strong_root_password

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_STORE=redis
SESSION_ENCRYPT=true
SESSION_LIFETIME=120

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=change_this_redis_password
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="billing@skynet.id"
MAIL_FROM_NAME="${APP_NAME}"

FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

RADIUS_AUTH_PORT=1812
RADIUS_ACCT_PORT=1813
RUN_SEEDERS=true

VITE_APP_NAME="${APP_NAME}"
